-- ATUALIZAÇÃO DO PREÇO E QUANTIDADE EM ESTOQUE
UPDATE produtos
SET preco_unitario = 850.50,
quantidade_estoque = 35
WHERE id_produto = 12;

UPDATE produtos
SET preco_unitario = 4200.00,
quantidade_estoque =  12
WHERE id_produto = 13;

-- MOSTRA NOME DO FORNECEDOR E VALOR TOTAL EM ESTOQUE
SELECT 
f.nome_fornecedor,
SUM(p.preco_unitario * p.quantidade_estoque) AS valor_total_estoque
FROM fornecedores f
JOIN produtos p ON f.id_fornecedor = p.id_fornecedor
GROUP BY f.id_fornecedor, f.nome_fornecedor

