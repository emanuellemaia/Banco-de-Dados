-- mostrar clientes que moram onde tem agencias
SELECT c.cod_cliente, c.cliente
FROM cliente c, agencia a
WHERE c.localidade = a.localidade;

-- mostrar clientes que moram no mesmo lugar da agencia que têm conta
SELECT c.cod_cliente, c.cliente
FROM cliente c, conta ct, agencia a
WHERE c.cod_cliente = ct.cod_cliente
AND ct.cod_agencia = a.cod_agencia
AND c.localidade = a.localidade;

-- mostrar clientes que tem emprestimo maior que 2500
