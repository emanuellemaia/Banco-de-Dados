-- mostra quantas contas existem
SELECT COUNT(*) 
FROM conta;


-- mostra quantos clientes têm conta na agencia 123
SELECT COUNT(DISTINCT cod_cliente)
FROM conta
WHERE cod_agencia = '123';

 -- mostra número de conta por agencia
SELECT cod_agencia, COUNT(*)
FROM conta
GROUP BY cod_agencia;


-- mostra clientes com profissão desconhecida
SELECT cod_cliente, cliente
FROM cliente
WHERE profissao IS NULL;


 -- mostra para cada agencia com menos 1000 contas, os valores máximos, mínimos e saldo médio
SELECT cod_agencia,
       MAX(saldo) AS saldo_maximo,
       MIN(saldo) AS saldo_minimo,
       AVG(saldo) AS saldo_medio
FROM conta
GROUP BY cod_agencia
HAVING COUNT(*) < 1000;

-- mostra clientes que são apenas depositantes
SELECT c.cod_cliente, c.cliente
FROM cliente c
JOIN conta ct ON c.cod_cliente = ct.cod_cliente
WHERE ct.cod_agencia = '123'
AND c.cod_cliente NOT IN (
    SELECT cod_cliente
    FROM emprestimo
    WHERE cod_agencia = '123'
);


-- cliente com pelo menos um empréstimo
SELECT DISTINCT c.cod_cliente, c.cliente
FROM cliente c
JOIN emprestimo e ON c.cod_cliente = e.cod_cliente;

-- mostra agencias com depositantes que mostram em Lisboa 
SELECT DISTINCT a.cod_agencia, a.agencia
FROM agencia a
JOIN conta ct ON a.cod_agencia = ct.cod_agencia
JOIN cliente c ON ct.cod_cliente = c.cod_cliente
WHERE c.localidade = 'Lisboa';


-- mostra clientes com saldo maiores que o empréstimo 
SELECT c.cod_cliente, c.cliente
FROM cliente c
JOIN conta ct ON c.cod_cliente = ct.cod_cliente
GROUP BY c.cod_cliente, c.cliente
HAVING SUM(ct.saldo) > (
    SELECT MAX(valor)
    FROM Emprestimo
);

