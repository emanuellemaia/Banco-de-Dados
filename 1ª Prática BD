CREATE TABLE mentores (
 id_mentor INTEGER PRIMARY KEY AUTOINCREMENT,
 nome VARCHAR(150) NOT NULL,
 email VARCHAR(100) NOT NULL UNIQUE,
 anos_experiencia INT NOT NULL,
 biografia TEXT
);

CREATE TABLE alunos(
  id_aluno INTEGER PRIMARY KEY AUTOINCREMENT,
  nome VARCHAR(100) NOT NULL,
  email VARCHAR(100) UNIQUE NOT NULL,
  nivel_experiência VARCHAR(50),
  objetivos TEXT
);

CREATE TABLE areas(
	id_area INTEGER PRIMARY KEY AUTOINCREMENT,
	nome_area VARCHAR(100) UNIQUE NOT NULL
);

CREATE TABLE mentor_areas (
id_mentor INT,
id_area INT,
PRIMARY KEY (id_mentor, id_area),
FOREIGN KEY (id_mentor) REFERENCES mentores(id_mentor) ON DELETE CASCADE,
FOREIGN KEY (id_area) REFERENCES areas(id_area) ON DELETE CASCADE
);

